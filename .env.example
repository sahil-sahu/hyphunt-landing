# =========================================================================
# HYPHUNT LANDING ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================

# Resend API Key for automated welcome emails.
# Leave blank to enable "Mock Mode" (prints styled email output in terminal logs).
# Obtain key at: https://resend.com
RESEND_API_KEY=

# Sender email address registered and verified in your Resend account.
# Example: welcome@hyphunt.xyz or hello@yourdomain.com
SENDER_EMAIL=welcome@hyphunt.xyz
